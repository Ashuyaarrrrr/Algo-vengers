# ════════════════════════════════════════════════════════════════
#  HerbChain Backend — Environment Variables
#  Copy this file to .env and fill in the values.
# ════════════════════════════════════════════════════════════════

# Blockchain RPC (Hardhat local node)
RPC_URL=http://127.0.0.1:8545

# Contract address (output of: npx hardhat run scripts/deploy.js --network localhost)
CONTRACT_ADDRESS=

# Optional: Backend signer for server-side admin transactions (role granting etc.)
# Use one of the Hardhat test account private keys for local dev.
# NEVER commit a real private key!
BACKEND_PRIVATE_KEY=

# Supabase — use service_role key for backend (bypasses RLS)
SUPABASE_URL=https://hxatmdggoxpvccjfexpx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Express server port
PORT=3001
