# ─── HerbChain Blockchain Environment ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# Deployer wallet private key (export from MetaMask → Account Details)
# For local testing, Hardhat auto-generates 20 funded accounts — you don't need this.
DEPLOYER_PRIVATE_KEY=

# RPC URLs (needed only for testnet / mainnet deployments — not for local)
POLYGON_AMOY_RPC_URL=
POLYGON_MAINNET_RPC_URL=

# Block explorer API keys (for contract verification)
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
